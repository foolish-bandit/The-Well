---
import Base from '../../layouts/Base.astro';
import { getAllJudges, getJurisdictions, jurisdictionName } from '../../lib/judges';

const jurisdictions = getJurisdictions();
const judges = getAllJudges();
---
<Base title="Judges" description="Browse judges by jurisdiction.">
  <article class="reference-page">
    <header class="page-heading">
      <h1>Judges</h1>
      <p>
        This index lists published judge procedure pages by jurisdiction. Early
        records may include reference data while live jurisdiction coverage is
        prepared.
      </p>
    </header>
  {jurisdictions.length === 0 ? (
    <p style="color: var(--color-muted)">
      Judge pages are not yet published. The first jurisdiction (S.D. Cal.) is
      in preparation.
    </p>
  ) : (
    <div class="index-list">
      {jurisdictions.map((j) => (
        <section>
          <h2>{j.name}</h2>
          <p>{j.count} published judge{j.count === 1 ? '' : 's'}</p>
          <ul class="judge-link-list">
            {judges
              .filter((judge) => judge.jurisdiction === j.slug)
              .map((judge) => (
                <li>
                  <a href={`/j/${judge.jurisdiction}/${judge.slug}/`}>
                    {judge.honorific ?? 'Hon.'} {judge.name}
                  </a>
                  <span>{judge.status} - {jurisdictionName(judge.jurisdiction)}</span>
                </li>
              ))}
          </ul>
        </section>
      ))}
    </div>
  )}
  </article>
</Base>
